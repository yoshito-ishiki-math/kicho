#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
使い方:
  newpaper <作成先フォルダ> [論文タイトル]

例:
  newpaper MyPaper
  newpaper ~/Documents/Mypapers/Lipschitz-Retracts "Lipschitz Retracts in Metric Spaces"
EOF
}

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage
  exit 1
fi

target="${1%/}"
title="${2:-$(basename "$target")}"

if [[ -e "$target" ]]; then
  echo "エラー: '$target' はすでに存在します。" >&2
  exit 1
fi

mkdir -p \
  "$target/preamble" \
  "$target/sections" \
  "$target/figures" \
  "$target/bib" \
  "$target/build" \
  "$target/.vscode"

cat > "$target/main.tex" <<EOF
%!TEX program = LuaLaTeX
\documentclass[11pt]{article}

\input{preamble/packages}
\input{preamble/theorem}
\input{preamble/macros}

\title{$title}
\author{}
\date{\today}

\begin{document}

\maketitle

\begin{abstract}
Write the abstract here.
\end{abstract}

\input{sections/introduction}
\input{sections/preliminaries}
\input{sections/main-results}

\appendix
\input{sections/appendix}

\printbibliography

\end{document}
EOF

cat > "$target/preamble/packages.tex" <<'EOF'
\usepackage{fontspec}
\usepackage{amsmath,amssymb,mathtools}
\usepackage{amsthm}
\usepackage{microtype}
\usepackage{hyperref}
\usepackage[nameinlink,noabbrev]{cleveref}
\usepackage[
  backend=biber,
  style=alphabetic,
  maxnames=99
]{biblatex}

\addbibresource{bib/references.bib}
EOF

cat > "$target/preamble/theorem.tex" <<'EOF'
\theoremstyle{plain}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{corollary}[theorem]{Corollary}

\theoremstyle{definition}
\newtheorem{definition}[theorem]{Definition}
\newtheorem{example}[theorem]{Example}

\theoremstyle{remark}
\newtheorem{remark}[theorem]{Remark}
EOF

cat > "$target/preamble/macros.tex" <<'EOF'
\newcommand{\R}{\mathbb{R}}
\newcommand{\N}{\mathbb{N}}
\newcommand{\Z}{\mathbb{Z}}
\newcommand{\Q}{\mathbb{Q}}
\newcommand{\C}{\mathbb{C}}

\DeclareMathOperator{\diam}{diam}
\DeclareMathOperator{\dist}{dist}
\DeclareMathOperator{\Lip}{Lip}
EOF

cat > "$target/sections/introduction.tex" <<'EOF'
\section{Introduction}

Write the introduction here.
EOF

cat > "$target/sections/preliminaries.tex" <<'EOF'
\section{Preliminaries}

Write the preliminaries here.
EOF

cat > "$target/sections/main-results.tex" <<'EOF'
\section{Main results}

\begin{theorem}
State the main theorem here.
\end{theorem}

\begin{proof}
Write the proof here.
\end{proof}
EOF

cat > "$target/sections/appendix.tex" <<'EOF'
\section{Appendix}

Write the appendix here.
EOF

cat > "$target/bib/references.bib" <<'EOF'
% Add BibLaTeX entries here.
EOF

cat > "$target/.latexmkrc" <<'EOF'
$pdf_mode = 4;
$lualatex = 'lualatex -synctex=1 -interaction=nonstopmode -file-line-error %O %S';

$bibtex = 'biber %O %B';

$max_repeat = 5;
EOF

cat > "$target/.gitignore" <<'EOF'
# LaTeX auxiliary files
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc

# Build directory
build/*
!build/.gitkeep

# macOS
.DS_Store
EOF

cat > "$target/.vscode/settings.json" <<'EOF'
{
    "latex-workshop.latex.recipe.default": "latexmk (lualatex)",
    "latex-workshop.latex.autoBuild.run": "onSave",
    "latex-workshop.view.pdf.viewer": "tab",
    "latex-workshop.synctex.afterBuild.enabled": true
}
EOF

cat > "$target/README.md" <<EOF
# $title

LuaLaTeX + latexmk 用の論文プロジェクトです。

## ビルド

\`\`\`bash
latexmk main.tex
\`\`\`

## クリーン

\`\`\`bash
latexmk -C
\`\`\`
EOF

touch "$target/build/.gitkeep"

if command -v git >/dev/null 2>&1; then
  git -C "$target" init -q
fi

echo
echo "作成しました: $target"
echo
echo "次のコマンドで開けます:"
echo "  cd \"$target\""
if command -v code >/dev/null 2>&1; then
  echo "  code ."
fi
