#!/usr/bin/env bash

set -e

KICHO_BIN_DIR="$(
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &&
    pwd
)"

KICHO_ROOT="$(
    cd -- "$KICHO_BIN_DIR/.." &&
    pwd
)"

KICHO_LIB_DIR="$KICHO_ROOT/lib/kicho"

source "$KICHO_LIB_DIR/common.sh"
source "$KICHO_LIB_DIR/loader.sh"

kicho_load_commands
kicho_dispatch "$@"
