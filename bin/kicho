#!/usr/bin/env bash

set -e

KICHO_BIN_DIR="$(
    cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &&
    pwd
)"

KICHO_ROOT="$(
    cd -- "$KICHO_BIN_DIR/.." &&
    pwd
)"

KICHO_LIB_DIR="$KICHO_ROOT/lib/kicho"

source "$KICHO_LIB_DIR/common.sh"
source "$KICHO_LIB_DIR/init.sh"
source "$KICHO_LIB_DIR/build.sh"
source "$KICHO_LIB_DIR/clean.sh"

main() {
    case "${1:-}" in
        "")
            kicho_show_help
            ;;

        -h|--help)
            kicho_show_help
            ;;

        -v|--version)
            kicho_show_version
            ;;

        init)
            kicho_init "${2:-}"
            ;;

        build)
            kicho_build
            ;;

        clean)
            kicho_clean
            ;;

        *)
            kicho_error "unknown command '$1'."
            printf "Run 'kicho --help' for usage.\n" >&2
            exit 1
            ;;
    esac
}

main "$@"
